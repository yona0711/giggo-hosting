rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeen(age) {
      return age is int && age >= 13 && age <= 17;
    }

    function validCreate(userId) {
      return isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.age is int
        && request.resource.data.age >= 13
        && request.resource.data.dateOfBirth is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.parentEmail is string
        && request.resource.data.approvalStatus is string
        && (
          (isTeen(request.resource.data.age)
            && request.resource.data.parentEmail.size() > 3
            && request.resource.data.approvalStatus == 'pending')
          ||
          (!isTeen(request.resource.data.age)
            && request.resource.data.parentEmail == ''
            && request.resource.data.approvalStatus == 'approved')
        );
    }

    function validOwnerUpdate(userId) {
      return isOwner(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.age == resource.data.age
        && request.resource.data.dateOfBirth == resource.data.dateOfBirth
        && request.resource.data.parentEmail == resource.data.parentEmail
        && request.resource.data.approvalStatus == resource.data.approvalStatus
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if validCreate(userId);
      allow update: if validOwnerUpdate(userId);
      allow delete: if false;
    }

    match /gigs/{gigId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.providerUid == request.auth.uid
        && request.resource.data.providerUid == resource.data.providerUid;
      allow delete: if isSignedIn()
        && resource.data.providerUid == request.auth.uid;
    }

    match /servicePages/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.ownerUid == userId;
      allow delete: if false;
    }

    match /trustReports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.contentType is string
        && request.resource.data.targetId is string
        && request.resource.data.targetOwnerUid is string
        && request.resource.data.targetOwnerName is string
        && request.resource.data.reason is string
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /serviceConversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if isSignedIn()
        && request.resource.data.clientUid == request.auth.uid
        && request.resource.data.providerUid is string
        && request.resource.data.providerName is string
        && request.resource.data.clientName is string
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.resource.data.participantUids[0] == request.resource.data.providerUid
        && request.resource.data.participantUids[1] == request.resource.data.clientUid
        && request.resource.data.lastMessage is string
        && request.resource.data.lastUpdated is timestamp;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.providerUid == resource.data.providerUid
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.providerName == resource.data.providerName
        && request.resource.data.clientName == resource.data.clientName
        && request.resource.data.lastMessage is string
        && request.resource.data.lastUpdated is timestamp;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(
          /databases/$(database)/documents/serviceConversations/$(conversationId)
        ).data.participantUids;
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.senderName is string
          && request.resource.data.text is string
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }
    }

    match /escrows/{escrowId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && request.resource.data.gigId == resource.data.gigId
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.id == resource.data.id
        && request.resource.data.status is string;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
