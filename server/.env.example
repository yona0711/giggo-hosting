# Server
PORT=4000
APP_BASE_URL=http://localhost:3000

# Comma-separated browser origins allowed to call this API.
# Leave blank for local development. Set in production, for example:
# CORS_ORIGINS=https://giggo-8a302.web.app,https://www.yourgiggoapp.com
CORS_ORIGINS=

# Stripe (required for live Stripe mode)
# Get from Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Webhooks (required for webhook signature verification)
# Get from: stripe listen --forward-to http://localhost:4000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Server persistence
# Use "file" for local development. Use "firestore" for production deployment.
GIGGO_STORE_DRIVER=file
GIGGO_STORE_COLLECTION=_serverState
GIGGO_STORE_DOCUMENT=runtime
